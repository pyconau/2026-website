---
import { getCollection } from "astro:content";
import Footer from "../../../components/Footer.astro";
import Header from "../../../components/Header.astro";
import HeaderStar from "../../../components/header/HeaderStar.astro";
import Base from "../../../layouts/Base.astro";
import SessionListItem from "../../../components/schedule/SessionListItem.astro";
import { getSessionsForSpecialistTrack } from "../../../utils/schedule";

export async function getStaticPaths() {
  const tracks = await getCollection("specialist-tracks");
  return tracks.map((track) => ({
    params: { slug: track.slug },
    props: { track },
  }));
}

const { track } = Astro.props;
const { title, shortDescription } = track.data;
const { Content } = await track.render();

// Get sessions for this track
const sessions = await getSessionsForSpecialistTrack(track);
---

<Base title={`${title} - Specialist Track`}>
  <Header dark={true} />

  <section class="bg-charcoal pt-[98px] pb-20 overflow-hidden">
    <div class="container relative">
      <img
        src="/images/star-violet.svg"
        class="hidden lg:block absolute left-0 top-32"
        alt=""
      />
      <div class="lg:w-[85%] w-full mx-auto">
        <div class="fadeInUp breadcrumb pt-14">
          <ul class="flex items-center gap-2 text-lime font-sans font-extrabold text-10pt uppercase tracking-[0.12em]">
            <li class="flex items-center gap-2">
              <a href="/">Home</a><span>&gt;</span>
            </li>
            <li class="flex items-center gap-2">
              <a href="/program">Program</a><span>&gt;</span>
            </li>
            <li class="flex items-center gap-2">
              <a href="/program/specialist-tracks">Specialist Tracks</a>
            </li>
          </ul>
        </div>
        <div class="fadeInUp flex justify-between items-center relative pt-10">
          <div class="space-y-20 lg:w-[45%] w-full relative">
            <div class="font-serif lg:text-8xl text-[3.625rem] -tracking-[0.022em] leading-none">
              <h1 class="text-lime">{title}</h1>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="header-divider header-divider--lime"></div>

    <div class="bg-stone pt-20 pb-52">
      <div class="container">
        <div class="fadeInUp lg:w-[85%] w-full mx-auto">
          <div class="flex lg:flex-row flex-col lg:gap-0 gap-10 justify-between items-start">
            <div class="text-intro font-medium w-full text-charcoal lg:w-[646px] prose prose-lg">
              <p>{shortDescription}</p>
              <Content />
            </div>
            <div>
              <a href="/cfp" class="btn-arrow btn-arrow--emerald">
                Submit a Talk
              </a>
            </div>
          </div>

          {sessions.length > 0 && (
            <div class="pt-24">
              <h3 class="fadeInUp text-5xl font-serif font-medium -tracking-[0.02em] mb-10">
                Sessions
              </h3>

              <div class="space-y-10">
                {sessions.map((session) => (
                  <SessionListItem session={session} />
                ))}
              </div>
            </div>
          )}

          {sessions.length === 0 && (
            <div class="pt-24">
              <p class="text-charcoal/70 text-lg">
                Sessions for this track will be announced after the Call for
                Proposals closes.
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-lime pt-20">
    <div class="container">
      <div class="grid lg:grid-cols-2 grid-cols-1 gap-5 pb-20 fadeInUp">
        <a href="/program" class="btn-arrow btn-arrow--emerald btn-arrow--2col">
          <span>Full Program</span>
        </a>
        <a
          href="/program/specialist-tracks"
          class="btn-arrow btn-arrow--emerald btn-arrow--2col"
        >
          <span>All Specialist Tracks</span>
        </a>
      </div>
    </div>
  </section>

  <Footer topColour="lime" />

  <script src="/src/scripts/animations.js"></script>
</Base>
