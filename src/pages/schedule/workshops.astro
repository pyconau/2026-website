---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Base from "../../layouts/Base.astro";
import SessionListItem from "../../components/schedule/SessionListItem.astro";
import TrackTicketCard from "../../components/schedule/TrackTicketCard.astro";
import type { TicketTier } from "../../components/schedule/TrackTicketCard.astro";
import FAQEntry from "../../components/attend/faq/FAQEntry.astro";
import { getWorkshopSessions } from "../../utils/schedule";
import { TICKETING_URL } from "../../constants";

// Workshops run on Wednesday 26 August 2026.
const formattedDate = "Wednesday 26 August";
const dayParam = "wednesday";

// Workshop ticketing: free for all conference delegates, or a workshops-only
// ticket. Tier names use the sprints card text colour (charcoal), and prices
// show a flat figure with no "From" label or secondary pricing subtext.
const ticketTiers: TicketTier[] = [
  {
    name: "Free to attend",
    nameColour: "text-charcoal",
    description: "For all conference delegates.",
    price: "Free",
    showFromLabel: false,
  },
  {
    name: "Workshops Only",
    nameColour: "text-charcoal",
    description: "To attend just the workshops.",
    price: "$150",
    showFromLabel: false,
  },
];

const sessions = await getWorkshopSessions();
---

<Base title="Workshops - Schedule">
  <Header dark={true} />

  <section class="bg-charcoal pt-[98px] pb-20 overflow-hidden">
    <div class="container relative">
      <img
        src="/images/star-lime.svg"
        class="hidden lg:block absolute left-0 top-32"
        alt=""
      />
      <div class="lg:w-[85%] w-full mx-auto">
        <div class="fadeInUp breadcrumb pt-14">
          <ul class="flex items-center gap-2 text-lime font-sans font-extrabold text-10pt uppercase tracking-[0.12em]">
            <li class="flex items-center gap-2">
              <a href="/">Home</a><span>&gt;</span>
            </li>
            <li class="flex items-center gap-2">
              <a href="/schedule">Schedule</a><span>&gt;</span>
            </li>
            <li class="flex items-center gap-2">
              <span>Workshops</span>
            </li>
          </ul>
        </div>
        <div class="fadeInUp flex justify-between items-center relative pt-10">
          <div class="space-y-20 lg:w-[45%] w-full relative">
            <div class="space-y-5">
              <div class="font-serif lg:text-8xl text-[3.625rem] -tracking-[0.022em] leading-none">
                <h1 class="text-lime">Workshops</h1>
              </div>
              <p class="text-stone font-sans text-base tracking-[0.01em]">
                Will run on {formattedDate}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="header-divider header-divider--lime"></div>

    <div class="bg-stone pt-20 pb-52">
      <div class="container">
        <div class="fadeInUp lg:w-[85%] w-full mx-auto">
          <div class="flex lg:flex-row flex-col lg:gap-20 gap-10 justify-between items-start">
            <div class="w-full lg:w-[646px]">
              <p class="text-intro font-medium text-charcoal fadeInUp">
                Hands-on, instructor led sessions to learn new tools, technology
                and skills. They're free to attend but require separate
                registration.
              </p>
              <div class="rich-text mt-6 fadeInUp">
                <p>
                  Workshops are run by members of the PyCon AU community, or by
                  our sponsors. Capacity is limited and its important you
                  register specifically for each workshop you intend on joining.
                </p>
                <p>
                  If you or your team would like to attend just the workshops,
                  you can purchase a "Just the workshops" ticket to attend on
                  Wednesday 26 August.
                </p>
              </div>
            </div>
            <TrackTicketCard
              trackName="Workshops"
              date={formattedDate}
              tiers={ticketTiers}
            />
          </div>

          <div class="pt-24">
            <h3 class="fadeInUp text-5xl font-serif font-medium -tracking-[0.02em] mb-10">
              How to register for workshops
            </h3>
            <div class="fadeInUp space-y-4">
              <FAQEntry title="I'm already registered - can I add workshops?">
                <ol>
                  <li>
                    View your order online using the link emailed to you at the
                    time of purchase. Alternatively, use the "resend order link"
                    feature by entering your email at
                    <a href={TICKETING_URL} target="_blank" rel="noopener noreferrer">
                      {TICKETING_URL}
                    </a>
                  </li>
                  <li>
                    Scroll down and "Change your order". Here you can update
                    add-ons, including workshops and extra shirts etc. Be sure to
                    save your updated order.
                  </li>
                  <li>
                    Make sure you "Update details", to answer additional required
                    questions for the add-on products you've added to your ticket.
                  </li>
                </ol>
              </FAQEntry>
              <FAQEntry title="I'm about to register - how do I include workshops?">
                <p>
                  Simply register for your ticket as normal. On the second step,
                  you'll be prompted to select add-ons including t-shirt sizes and
                  specific workshops.
                </p>
              </FAQEntry>
            </div>
          </div>

          {sessions.length > 0 && (
            <div class="pt-24">
              <div class="fadeInUp flex flex-wrap items-center justify-between gap-x-10 gap-y-4 mb-10">
                <h3 class="text-5xl font-serif font-medium -tracking-[0.02em]">
                  Sessions
                </h3>
                <a href={`/schedule/${dayParam}`} class="btn-arrow btn-arrow--lime">
                  <span>Wednesday schedule</span>
                </a>
              </div>

              <div class="space-y-10">
                {sessions.map((session) => (
                  <SessionListItem session={session} />
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-lime pt-20">
    <div class="container">
      <div class="grid lg:grid-cols-2 grid-cols-1 gap-5 pb-20 fadeInUp">
        <a href="/schedule" class="btn-arrow btn-arrow--emerald btn-arrow--2col">
          <span>Full Program</span>
        </a>
        <a
          href="/schedule/specialist-tracks"
          class="btn-arrow btn-arrow--emerald btn-arrow--2col"
        >
          <span>Specialist Tracks</span>
        </a>
      </div>
    </div>
  </section>

  <Footer topColour="lime" />

  <script src="/src/scripts/animations.js"></script>
</Base>
