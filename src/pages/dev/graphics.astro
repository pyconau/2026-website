---
// Dev page to view all generated session graphics
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const sessions = await getCollection("sessions");
const sessionGraphics = sessions
  .filter((s) => s.data.type !== "break")
  .map((s) => ({
    code: s.data.code,
    title: s.data.title,
    layout: s.data.layout || "layout_2",
    path: `/graphics/sessions/${s.data.code}-${s.data.layout || "layout_2"}.png`,
  }))
  .sort((a, b) => a.code.localeCompare(b.code));
---

<Base title="Session Graphics Gallery">
  <div class="min-h-screen bg-gray-900 p-8">
    <div class="mx-auto max-w-full">
      <h1 class="mb-8 text-4xl font-bold text-white">
        Session Graphics Gallery ({sessionGraphics.length})
      </h1>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {
          sessionGraphics.map((graphic) => (
            <div
              class="cursor-pointer overflow-hidden rounded-lg bg-gray-800 shadow-lg transition-transform hover:scale-105"
              onclick={`document.getElementById('modal').style.display = 'flex'; document.getElementById('modal-img').src = '${graphic.path}'; document.getElementById('modal-title').textContent = '${graphic.code}: ${graphic.title}';`}
            >
              <img
                src={graphic.path}
                alt={graphic.title}
                class="h-auto w-full"
                loading="lazy"
              />
              <div class="p-3">
                <p class="truncate text-sm font-mono text-gray-300">
                  {graphic.code}
                </p>
                <p class="truncate text-xs text-gray-400">{graphic.title}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Modal -->
    <div
      id="modal"
      class="fixed inset-0 hidden flex-col items-center justify-center bg-black/80 p-4"
      onclick="if(event.target === this) this.style.display = 'none'"
    >
      <button
        class="absolute top-4 right-4 text-white text-2xl hover:text-gray-300"
        onclick="document.getElementById('modal').style.display = 'none'"
      >
        ✕
      </button>
      <div class="max-h-[90vh] max-w-4xl overflow-auto rounded-lg bg-gray-900">
        <img id="modal-img" src="" alt="" class="w-full" />
        <div class="p-4">
          <p id="modal-title" class="text-lg text-white"></p>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  #modal {
    display: none;
  }
</style>
